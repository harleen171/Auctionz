# Copy this file to .env and fill in your actual values
NODE_ENV=development
PORT=5000
HOST=localhost

# MongoDB — use your Atlas connection string OR local mongod.
# Atlas: Database → Connect → Drivers → copy URI (replace <password>).
# Example: mongodb+srv://user:pass@cluster.mongodb.net/auctionz?retryWrites=true&w=majority
# If Atlas times out on Windows, try adding: MONGO_IPV4_ONLY=1
MONGO_URI=mongodb://127.0.0.1:27017/auctionz

# Optional: force IPv4 for MongoDB driver (some Atlas / Wi‑Fi setups)
MONGO_IPV4_ONLY=1

# JWT Secret (keep this very secure!)
JWT_SECRET=change_this_to_a_strong_secret_key

JWT_EXPIRE_IN=7d

# Session Secret
SESSION_SECRET=change_this_to_a_strong_secret_key

SOCKET_IO_PATH=/socket.io
CORS_ORIGIN=http://localhost:5000
LOG_LEVEL=debug
